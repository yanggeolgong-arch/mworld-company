# ===========================================
# 뷰카운트 (무조건 동작) - 필수
# ===========================================
# 1. Firebase Console (console.firebase.google.com)
#    - 프로젝트 생성 또는 선택
#    - Firestore Database 생성
#    - 프로젝트 설정 > 서비스 계정 > "키 추가" > 새 비공개 키 생성
#    - 다운로드된 JSON 파일 내용 전체를 한 줄로 만든 뒤 아래 변수에 붙여넣기
#
# 2. .env.local (로컬) 및 Vercel 환경변수 (배포) 에 추가:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
#
# 3. Firestore 규칙 (읽기/쓰기 허용):
#    match /artifacts/{appId}/public/data/stats/{doc} {
#      allow read, write: if true;
#    }
#    또는 인증 필요 시: allow read, write: if request.auth != null;
#    규칙 배포: firebase deploy --only firestore
#
# ===========================================
# 선택: 실시간 stats 표시 (클라이언트)
# ===========================================
# FIREBASE_SERVICE_ACCOUNT_JSON 만 있어도 뷰카운트 동작함.
# 실시간 onSnapshot 대신 3초 폴링 사용. 실시간 원하면 추가:
# NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
# Authentication > 익명 사용 ON
#
# ===========================================
# 어드민
# ===========================================
ADMIN_SECRET=비밀번호
# 접속: /ko/stealth-best-10?_adm=비밀번호
# ===========================================
